# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Supabase Configuration
# Primary source is mobile_app/lib/kids_commercedb/supabase.env
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_DB_URL=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Email Configuration (for notifications)
MAIL_SENDER=your-email@gmail.com
MAIL_APP_PASSWORD=your-app-password

# EmailListVerify (real-time email validation)
# Get your API key from https://emaillistverify.com/ and set it here.
EMAILLISTVERIFY_API_KEY=

# PayMongo Configuration (Payment Gateway)
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key_here
PAYMONGO_SECRET_KEY=sk_test_your_secret_key_here

# Upload Folder
UPLOAD_FOLDER=static/uploads
