# ============================================
# GOOGLE OAUTH CREDENTIALS
# ============================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-public-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ============================================
# FLASK APPLICATION SETTINGS
# ============================================
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-here-change-in-production"
FLASK_ENV="development"
DEBUG="True"

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://user:password@host:port/database"

# ============================================
# SERVER CONFIGURATION
# ============================================
HOST="0.0.0.0"
PORT="5000"

# ============================================
# CORS SETTINGS
# ============================================
ALLOWED_ORIGINS="http://localhost:3000,http://192.168.1.26:5000"

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Email sender for verification, password reset, notifications
MAIL_SENDER="your-email@gmail.com"
MAIL_APP_PASSWORD="your-16-char-app-password"
MAIL_SENDER_NAME="Kids Kingdom"

# ============================================
# EMAIL VERIFICATION API
# ============================================
# EmailListVerify API for real-time email validation
# Get your API key from: https://emaillistverify.com/
# If not set, will use basic regex validation as fallback
EMAILLISTVERIFY_API_KEY="your-api-key-here"

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit .env to version control
# 4. Keep .env in .gitignore
