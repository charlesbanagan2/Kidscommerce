# Uploads (use cloud storage in production)
# Allow all image files for deployment
!static/uploads/*.png
!static/uploads/*.jpg
!static/uploads/*.jpeg
!static/uploads/*.gif
!static/uploads/*.webp
!static/uploads/.gitkeep

# Exclude large files (videos, PSD) - use cloud storage instead
