{% block scripts %}
<!-- PSGC Dynamic Address Script -->
<script>
const PSGC = {
  regions: 'https://psgc.gitlab.io/api/regions/',
  provincesForRegion: code => `https://psgc.gitlab.io/api/regions/${encodeURIComponent(code)}/provinces/`,
  citiesForProvince: code => `https://psgc.gitlab.io/api/provinces/${encodeURIComponent(code)}/cities-municipalities/`,
  barangaysForCity: code => `https://psgc.gitlab.io/api/cities-municipalities/${encodeURIComponent(code)}/barangays/`
};

// Address label dropdown handlers
function setupLabelDropdown(prefix) {
    const labelTypeSelect = document.getElementById(`${prefix}_label_type`);
    const customLabelDiv = document.getElementById(`${prefix}_custom_label_div`);
    const customLabelInput = document.getElementById(`${prefix}_custom_label`);
    const labelHidden = document.getElementById(`${prefix}_label`);
    
    if (!labelTypeSelect) return;
    
    labelTypeSelect.addEventListener('change', function() {
        if (this.value === 'Custom') {
            customLabelDiv.style.display = 'block';
            customLabelInput.required = true;
            labelHidden.value = '';
        } else {
            customLabelDiv.style.display = 'none';
            customLabelInput.required = false;
            customLabelInput.value = '';
            labelHidden.value = this.value;
        }
    });
    
    customLabelInput?.addEventListener('input', function() {
        labelHidden.value = this.value;
    });
}

// Initialize label dropdowns for both modals
setupLabelDropdown('add');
setupLabelDropdown('edit');

// Toggle view/hide text on coupon dropdown
const viewCouponsBtn = document.getElementById('viewCouponsBtn');
if (viewCouponsBtn) {
    viewCouponsBtn.addEventListener('click', function() {
        const viewText = this.querySelector('.view-text');
        const hideText = this.querySelector('.hide-text');
        viewText.classList.toggle('d-none');
        hideText.classList.toggle('d-none');
    });
}

// Load available coupons when the dropdown is shown
document.getElementById('availableCoupons')?.addEventListener('shown.bs.collapse', function() {
    const couponList = document.getElementById('couponList');
    const couponCount = document.getElementById('couponCount');
    
    // Show loading state
    couponList.innerHTML = `
        <div class="list-group-item">
            <div class="d-flex align-items-center justify-content-center py-3">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="small text-muted">Loading available coupons...</span>
            </div>
        </div>`;
    
    // Fetch available coupons
    fetch('/api/available-coupons')
        .then(response => {
            if (!response.ok) throw new Error('Network response was not ok');
            return response.json();
        })
        .then(payload => {
            const data = payload?.coupons || [];
            if (!data || data.length === 0) {
                couponList.innerHTML = `
                    <div class="list-group-item">
                        <div class="text-center py-3">
                            <i class="fas fa-ticket-alt fa-2x text-muted mb-2"></i>
                            <p class="mb-0 small text-muted">No active coupons available at this time.</p>
                            <p class="small text-muted mb-0">Check back later for special offers!</p>
                        </div>
                    </div>`;
                if (couponCount) couponCount.textContent = '0';
                return;
            }
            
            // Update coupon count
            if (couponCount) couponCount.textContent = data.length;
            
            // Generate coupon list items
            couponList.innerHTML = data.map(coupon => {
                const validUntil = new Date(coupon.valid_until);
                const today = new Date();
                const isExpiringSoon = (validUntil - today) < (7 * 24 * 60 * 60 * 1000); // Within 7 days
                
                return `
                <div class="list-group-item p-0 border-0" data-code="${coupon.code}">
                    <div class="d-flex align-items-stretch h-100">
                        <!-- Coupon Visual -->
                        <div class="coupon-visual bg-primary bg-opacity-10 d-flex flex-column align-items-center justify-content-center p-3 border-end border-2 border-dashed border-primary">
                            <div class="text-primary fw-bold mb-1">
                                ${coupon.discount_type === 'percent' ? 
                                    `${coupon.discount_value}%` : 
                                    `₱${parseFloat(coupon.discount_value).toFixed(2)}`}
                            </div>
                            <div class="text-uppercase text-primary small fw-bold">OFF</div>
                        </div>
                        
                        <!-- Coupon Details -->
                        <div class="flex-grow-1 p-3">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h6 class="mb-0 fw-bold">${coupon.code}</h6>
                                <span class="badge ${isExpiringSoon ? 'bg-warning text-dark' : 'bg-success'} small">
                                    ${isExpiringSoon ? 'Expiring Soon' : 'Active'}
                                </span>
                            </div>
                            
                            <p class="small text-muted mb-2">${coupon.description || 'Special discount on your purchase'}</p>
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="coupon-valid small">
                                    <i class="far fa-clock me-1"></i>
                                    <span>Valid until ${validUntil.toLocaleDateString()}</span>
                                </div>
                            </div>
                            
                            ${coupon.min_order_amount ? `
                                <div class="mt-2 small text-muted">
                                    <i class="fas fa-shopping-cart me-1"></i>
                                    Min. order: ₱${parseFloat(coupon.min_order_amount).toFixed(2)}
                                </div>` : ''
                            }
                        </div>
                    </div>
                </div>`;
            }).join('');
            
            // Clicking a coupon should just fill the input (Apply button does the apply)
            document.querySelectorAll('#couponList .list-group-item').forEach(item => {
                item.style.cursor = 'pointer';
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    const code = this.getAttribute('data-code');
                    const input = document.getElementById('couponCodeInput');
                    if (input && code) {
                        input.value = code;
                        input.focus();
                    }
                });
            });
        })
        .catch(error => {
            console.error('Error loading coupons:', error);
            couponList.innerHTML = `
                <div class="list-group-item">
                    <div class="alert alert-warning mb-0" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <div>
                                <div class="fw-bold">Unable to load coupons</div>
                                <div class="small">Please check your connection and try again.</div>
                            </div>
                        </div>
                    </div>
                </div>`;
        });
});

// Handle coupon input Enter key submit
const couponInput = document.getElementById('couponCodeInput');
if (couponInput) {
    couponInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            const code = this.value.trim();
            if (!code) return;

            // Build target URL to checkout with coupon_code
            const url = new URL(window.location.pathname, window.location.origin);
            const existingParams = new URLSearchParams(window.location.search);
            existingParams.forEach((value, key) => {
                if (!url.searchParams.has(key)) {
                    url.searchParams.set(key, value);
                }
            });
            url.searchParams.set('coupon_code', code.toUpperCase().replace(/\s+/g, ''));
            window.location.href = url.toString();
        }
    });
}

// Address selection change handler
document.getElementById('address_select')?.addEventListener('change', function() {
    const selectedOption = this.options[this.selectedIndex];
    const fullAddress = selectedOption.getAttribute('data-full-address');
    document.getElementById('selected-address-display').textContent = fullAddress || 'No address selected';
});

// Edit address button handler
document.getElementById('btn-edit-address')?.addEventListener('click', async function() {
    const addressSelect = document.getElementById('address_select');
    const addressId = addressSelect.value;
    
    if (!addressId) {
        alert('Please select an address to edit');
        return;
    }
    
    try {
        const response = await fetch(`/api/get-address/${addressId}`);
        const data = await response.json();
        
        if (data.success) {
            const addr = data.address;
            
            // Set label - check if it's a predefined one or custom
            const editLabelType = document.getElementById('edit_label_type');
            const predefinedLabels = ['Home', 'Work', 'Office', 'School'];
            
            if (predefinedLabels.includes(addr.label)) {
                editLabelType.value = addr.label;
                document.getElementById('edit_label').value = addr.label;
            } else {
                editLabelType.value = 'Custom';
                document.getElementById('edit_custom_label_div').style.display = 'block';
                document.getElementById('edit_custom_label').value = addr.label;
                document.getElementById('edit_custom_label').required = true;
                document.getElementById('edit_label').value = addr.label;
            }
            
            document.getElementById('edit_street').value = addr.street;
            document.getElementById('edit_is_default').checked = addr.is_default;
            
            // Set form action
            document.getElementById('editAddressForm').action = `/edit-address/${addr.id}`;
            
            // Load regions and try to pre-select
            await initEditModal(addr);
        }
    } catch (error) {
        console.error('Error loading address:', error);
        alert('Failed to load address details');
    }
});

async function fetchJSON(url) {
    try {
        const r = await fetch(url);
        if (!r.ok) throw new Error('Network error');
        return await r.json();
    } catch (e) {
        console.warn('PSGC fetch failed:', e);
        return [];
    }
}

function optionize(sel, items, placeholder) {
    sel.innerHTML = `<option value="">${placeholder}</option>`;
    items.forEach(item => {
        const code = item.code || item.psgcCode || item.regionCode || item.provinceCode || item.cityMunCode || item.cityMunicipalityCode || item.barangayCode || item.brgyCode;
        const name = item.name || item.regionName || item.provinceName || item.cityMunName || item.cityName || item.barangayName || item.barangay;
        if (code && name) {
            const opt = document.createElement('option');
            opt.value = code;
            opt.textContent = name;
            sel.appendChild(opt);
        }
    });
}

function buildAddress(prefix) {
    const streetInp = document.getElementById(`${prefix}_street`);
    const regionSel = document.getElementById(`${prefix}_region`);
    const provSel = document.getElementById(`${prefix}_province`);
    const citySel = document.getElementById(`${prefix}_city`);
    const brgySel = document.getElementById(`${prefix}_barangay`);
    const finalTxt = document.getElementById(`${prefix}_full_address`);
    
    const street = streetInp.value.trim();
    const regionTx = regionSel.options[regionSel.selectedIndex]?.text || '';
    const provTx = provSel.options[provSel.selectedIndex]?.text || '';
    const cityTx = citySel.options[citySel.selectedIndex]?.text || '';
    const brgyTx = brgySel.options[brgySel.selectedIndex]?.text || '';
    
    const parts = [street, brgyTx, cityTx, provTx, regionTx].filter(Boolean);
    finalTxt.value = parts.join(', ');
    
    // Update hidden fields
    document.getElementById(`${prefix}_hidden_region`).value = regionTx;
    document.getElementById(`${prefix}_hidden_province`).value = provTx;
    document.getElementById(`${prefix}_hidden_city`).value = cityTx;
    document.getElementById(`${prefix}_hidden_barangay`).value = brgyTx;
    if (prefix === 'add') {
        document.getElementById('add_hidden_street').value = street;
    }
}

function setupPSGCDropdowns(prefix) {
    const regionSel = document.getElementById(`${prefix}_region`);
    const provSel = document.getElementById(`${prefix}_province`);
    const citySel = document.getElementById(`${prefix}_city`);
    const brgySel = document.getElementById(`${prefix}_barangay`);
    const streetInp = document.getElementById(`${prefix}_street`);
    
    regionSel.addEventListener('change', async () => {
        buildAddress(prefix);
        const code = regionSel.value;
        provSel.disabled = !code;
        citySel.disabled = true;
        brgySel.disabled = true;
        optionize(provSel, [], 'Select Province');
        optionize(citySel, [], 'Select City/Municipality');
        optionize(brgySel, [], 'Select Barangay');
        if (!code) return;
        const provinces = await fetchJSON(PSGC.provincesForRegion(code));
        optionize(provSel, provinces, 'Select Province');
    });
    
    provSel.addEventListener('change', async () => {
        buildAddress(prefix);
        const code = provSel.value;
        citySel.disabled = !code;
        brgySel.disabled = true;
        optionize(citySel, [], 'Select City/Municipality');
        optionize(brgySel, [], 'Select Barangay');
        if (!code) return;
        const cities = await fetchJSON(PSGC.citiesForProvince(code));
        optionize(citySel, cities, 'Select City/Municipality');
    });
    
    citySel.addEventListener('change', async () => {
        buildAddress(prefix);
        const code = citySel.value;
        brgySel.disabled = !code;
        optionize(brgySel, [], 'Select Barangay');
        if (!code) return;
        const barangays = await fetchJSON(PSGC.barangaysForCity(code));
        optionize(brgySel, barangays, 'Select Barangay');
    });
    
    brgySel.addEventListener('change', () => buildAddress(prefix));
    streetInp.addEventListener('input', () => buildAddress(prefix));
}

async function initEditModal(addr) {
    const regions = await fetchJSON(PSGC.regions);
    optionize(document.getElementById('edit_region'), regions, 'Select Region');
    // Note: Pre-selecting based on text names would require reverse lookup, complex for this implementation
    // For now, user must re-select from dropdowns
}

async function initAddModal() {
    const regions = await fetchJSON(PSGC.regions);
    optionize(document.getElementById('add_region'), regions, 'Select Region');
    
    // Reset label dropdown
    document.getElementById('add_label_type').value = '';
    document.getElementById('add_custom_label_div').style.display = 'none';
    document.getElementById('add_custom_label').value = '';
    document.getElementById('add_label').value = '';
}

// Initialize Add Modal
document.getElementById('addAddressModal').addEventListener('shown.bs.modal', initAddModal);

// Setup PSGC dropdowns for both modals
setupPSGCDropdowns('add');
setupPSGCDropdowns('edit');

// Reload page after adding address to update the list
document.getElementById('addAddressForm').addEventListener('submit', function() {
    // Add a flag to reload after form submission
    sessionStorage.setItem('reloadCheckout', 'true');
});

document.getElementById('editAddressForm').addEventListener('submit', function() {
    sessionStorage.setItem('reloadCheckout', 'true');
});

// Check if we should reload (after redirect back from add/edit)
if (sessionStorage.getItem('reloadCheckout') === 'true') {
    sessionStorage.removeItem('reloadCheckout');
    location.reload();
}

// Highlight newly added address and show success notification
