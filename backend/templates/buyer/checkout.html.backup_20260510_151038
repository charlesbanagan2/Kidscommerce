// Manual coupon application when Apply button is clicked
document.addEventListener('DOMContentLoaded', function() {
    // Don't add sample coupons - only show real ones
    // addSampleCoupons(); // REMOVED - no more fake coupons
    
    // Handle Apply button click
    const applyCouponBtn = document.getElementById('applyCouponBtn');
    if (applyCouponBtn) {
        applyCouponBtn.addEventListener('click', function() {
            const couponInput = document.getElementById('couponCodeInput');
            const couponCode = couponInput.value.trim();
            
            if (couponCode) {
                // Apply coupon directly without checking sample coupons
                applyCouponManually(couponCode, 0); // Will validate on server
            } else {
                // Show error for empty input
                const couponMessage = document.getElementById('couponMessage');
                if (couponMessage) {
                    couponMessage.innerHTML = `
                        <div class="alert alert-warning alert-dismissible fade show py-1 px-2 mb-0" role="alert">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <div>Please enter a coupon code</div>
                            </div>
                            <button type="button" class="btn-close p-1" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    `;
                }
            }
        });
    }
    
    // Handle coupon list item clicks - just fill the input, don't apply
    const couponList = document.getElementById('couponList');
    if (couponList) {
        couponList.addEventListener('click', function(e) {
            const couponItem = e.target.closest('.coupon-item');
            if (couponItem) {
                e.preventDefault();
                e.stopPropagation();
                
                const couponCode = couponItem.getAttribute('data-code');
                
                if (couponCode) {
                    const couponInput = document.getElementById('couponCodeInput');
                    if (couponInput) {
                        couponInput.value = couponCode;
                        couponInput.focus();
                    }
                }
            }
        });
    }
    
    // Coupon list is loaded on demand when the collapse is opened.
    
    // Function to apply coupon manually (when Apply button is clicked)
    function applyCouponManually(couponCode, discountAmount) {
        console.log('Applying coupon manually:', couponCode, discountAmount); // Debug log
        
        const couponInput = document.getElementById('couponCodeInput');
        const couponMessage = document.getElementById('couponMessage');
        
        // Show loading state briefly
        if (couponMessage) {
            couponMessage.innerHTML = `
                <div class="d-flex align-items-center">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                        <span class="visually-hidden">Applying...</span>
                    </div>
                    <span class="small text-muted">Applying coupon...</span>
                </div>
            `;
        }
        
        // Apply coupon after short delay
        setTimeout(() => {
            // Update total display
            const totalElement = document.querySelector('.text-primary.fs-5');
            let currentTotal = 0;
            let newTotal = 0;
            
            if (totalElement) {
                // Extract current total
                const totalText = totalElement.textContent.replace('₱', '').replace(',', '');
                currentTotal = parseFloat(totalText) || 0;
                
                // Check if this is a 100% discount (covers entire order)
                const originalSubtotal = parseFloat('{{ total|default(0) }}');
                const isFullDiscount = discountAmount >= originalSubtotal;
                
                // Calculate new total - if 100% discount, waive shipping fee
                if (isFullDiscount) {
                    newTotal = 0; // Free order - no shipping fee
                } else {
                    newTotal = Math.max(0, currentTotal - discountAmount);
                }
                
                console.log('Updating total from', currentTotal, 'to', newTotal, 'Full discount:', isFullDiscount); // Debug log
                
                // Update total display with animation
                totalElement.style.transition = 'all 0.3s ease';
                totalElement.style.color = '#28a745';
                totalElement.textContent = `₱${newTotal.toFixed(2)}`;
                
                // Add strikethrough effect to show discount
                if (discountAmount > 0) {
                    const originalTotal = document.createElement('span');
                    originalTotal.className = 'text-muted text-decoration-line-through small me-2';
                    originalTotal.textContent = `₱${currentTotal.toFixed(2)}`;
                    totalElement.parentNode.insertBefore(originalTotal, totalElement);
                }
            }
            
            // Show success message
            if (couponMessage) {
                couponMessage.innerHTML = `
                    <div class="alert alert-success alert-dismissible fade show py-1 px-2 mb-0" role="alert">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <i class="fas fa-check-circle me-2"></i>
                                <strong>Coupon Applied!</strong> You saved <strong>₱${discountAmount.toFixed(2)}</strong>
                            </div>
                            <a href="#" class="text-danger" onclick="removeCoupon(); return false;" title="Remove coupon">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    </div>
                `;
            }
            
            // Close coupon dropdown
            const couponCollapse = document.getElementById('availableCoupons');
            if (couponCollapse) {
                const bsCollapse = bootstrap.Collapse.getInstance(couponCollapse);
                if (bsCollapse) {
                    bsCollapse.hide();
                }
            }
            
            // Update button text
            const viewCouponsBtn = document.getElementById('viewCouponsBtn');
            if (viewCouponsBtn) {
                const viewText = viewCouponsBtn.querySelector('.view-text');
                const hideText = viewCouponsBtn.querySelector('.hide-text');
                if (viewText) viewText.classList.remove('d-none');
                if (hideText) hideText.classList.add('d-none');
            }
            
        }, 500); // Short delay for visual feedback
    }
    
    // Function to remove coupon
    window.removeCoupon = function() {
        const couponInput = document.getElementById('couponCodeInput');
        const couponMessage = document.getElementById('couponMessage');
        const totalElement = document.querySelector('.text-primary.fs-5');
        
        if (couponInput) {
            couponInput.value = '';
        }
        
        if (couponMessage) {
            couponMessage.innerHTML = `
                <div class="text-muted small d-flex align-items-center">
                    <i class="fas fa-info-circle me-1"></i>
                    <span>Enter a code or select from available coupons above</span>
                </div>
            `;
        }
        
        // Reset total display (remove strikethrough and restore original)
        if (totalElement) {
            totalElement.style.color = '';
            const strikethrough = totalElement.parentNode.querySelector('.text-decoration-line-through');
            if (strikethrough) {
                strikethrough.remove();
            }
        }
        
        return false;
    };
    
    // Initialize with no coupons available
    showNoCouponsAvailable();
});
</script>
